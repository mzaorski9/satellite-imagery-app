# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost

# Database — change password in production
POSTGRES_DB=satellite
POSTGRES_USER=sat_user
POSTGRES_PASSWORD=your-password-here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Celery / Redis — no changes needed for local setup
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# External APIs — required (see README)
SENTINEL_CLIENT_ID=your-sentinel-client-id
SENTINEL_CLIENT_SECRET=your-sentinel-client-secret
GROQ_API_KEY=your-groq-api-key